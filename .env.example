# ============================================================================
# .env.example — copie para .env e ajuste. NUNCA versionar o .env real.
# ============================================================================

APP_ENV=desenvolvimento          # desenvolvimento | homologacao | producao
APP_DEBUG=true                   # false em produção
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Sao_Paulo
APP_VERSION=dev                  # versão/commit publicado (aparece no /health e nas métricas)

# Aplicar migrations automaticamente no start do container (entrypoint).
# true em dev/homologação; considere false em produção (aplicar com backup).
AUTO_MIGRAR=true

# Banco de dados
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NOME=imunizacao
DB_USUARIO=root
DB_SENHA=

# Segurança
# Chave usada para HMAC/criptografia de dados sensíveis (gerar aleatória e única).
APP_CHAVE=troque-por-uma-chave-aleatoria-longa

# Sessão (segundos)
SESSAO_INATIVIDADE=1800          # 30 min
SESSAO_ABSOLUTA=28800            # 8 h

# Rate limit (requisições por minuto)
RATE_LIMIT_RPM=120               # padrão por credencial de parceiro (API)
RATE_LIMIT_LOGIN=20              # tentativas de login por IP/min
