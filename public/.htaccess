# ============================================================================
# public/.htaccess
# Roteia toda requisição que não seja arquivo/pasta real para o front controller.
# Assim /api/v1/... cai em public/index.php. Base: docs/05.
# ============================================================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Não reescrever arquivos ou diretórios existentes (assets estáticos).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo o resto vai para o front controller.
    RewriteRule ^ index.php [L]
</IfModule>

# Cabeçalhos de segurança básicos.
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
